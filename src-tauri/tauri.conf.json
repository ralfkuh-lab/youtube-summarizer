{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Summarizer",
  "version": "0.1.0",
  "identifier": "dev.ralf.youtube-summarizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "http://localhost:14220",
        "title": "YouTube Summarizer",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
